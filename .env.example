# ── Supabase ─────────────────────────────────────────────────────────────────
# Needed at BOTH build time (Vite inlines VITE_* into the client bundle) AND at
# runtime (server functions read them too). In Dokploy set these in BOTH the
# "Build Arguments" section AND the "Environment" section. See DEPLOY.md.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only secret — runtime Environment ONLY. Never a build arg, never VITE_-prefixed.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Admin ────────────────────────────────────────────────────────────────────
# Convenience PIN gate. Shipped to the client bundle (VITE_) — NOT a security
# boundary; real protection is Supabase auth + RLS. Needed at build AND runtime.
VITE_ADMIN_PIN=change_me

# Seeds / authenticates the admin login account. Server-only, runtime Environment.
ADMIN_EMAIL=admin@questlaguna.org
ADMIN_PASSWORD=your_admin_password
